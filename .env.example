# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fan_league:fan_league@localhost:5432/fan_league"
SESSION_SECRET="change-me"
CORS_ORIGIN="http://localhost:3000"
PORT=4000
HOST="0.0.0.0"
PREDICTION_LOCK_MINUTES=15
FOOTBALL_DATA_API_KEY=""

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# ── Production (docker-compose) — copy to .env on the server and fill in ─────
# POSTGRES_USER=league_user
# POSTGRES_PASSWORD=<generate: openssl rand -hex 16>
# POSTGRES_DB=league_db
# DATABASE_URL=postgresql://league_user:<password>@postgres:5432/league_db
# SESSION_SECRET=<generate: openssl rand -hex 32>
# CORS_ORIGIN=https://yourdomain.com
# FOOTBALL_DATA_API_KEY=
# NEXT_PUBLIC_API_BASE_URL=   # leave empty — frontend uses relative /api URLs via nginx
# SUPER_ADMIN_PASSCODE=       # passcode for super_admin (seeded on first deploy, default: 123456)
